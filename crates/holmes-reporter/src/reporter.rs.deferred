use std::path::{Path, PathBuf};

use holmes_core::state::validated::{Finding, FindingConfidence};
use holmes_core::state::AttackState;
use holmes_core::{Message, Role};
use holmes_llm::client::LlmClient;
use serde::{Deserialize, Serialize};
use thiserror::Error;
use tracing::{info, warn};

use crate::events::{AgentEvent, AgentEventSink};
use crate::hypothesis::{HypothesisStatus, HypothesisTracker};

pub const WRITEUP_SYSTEM_PROMPT: &str = r#"你是一个专业的渗透测试报告撰写专家。基于攻击过程生成详细的 CTF Writeup。

## Writeup 结构要求

### 1. 挑战概述
- 挑战名称和类型
- 目标 URL/IP
- 难度评估
- 关键提示

### 2. 侦察阶段
- 技术栈识别
- 端口和服务发现
- 攻击面枚举
- 关键观察

### 3. 漏洞发现
- 漏洞类型和位置
- 发现过程（如何识别）
- 漏洞原理解释
- 影响范围

### 4. 利用过程
- 攻击步骤（按时间顺序）
- 关键 payload 和技术
- 遇到的障碍和绕过方法
- 工具使用

### 5. Flag 获取
- 最终成功的方法
- Flag 位置和格式
- 验证过程

### 6. 经验总结
- 关键技术点
- 易错点和注意事项
- 类似漏洞的防御建议

## 输出格式

使用 Markdown 格式，代码块使用语法高亮。

## 写作风格

- 技术准确，逻辑清晰
- 面向学习者，解释原理而非仅列步骤
- 突出思路转折点和关键决策
- 总字数 1500-3000 字"#;

pub const VULN_REPORT_SYSTEM_PROMPT: &str = r#"你是一个专业的安全漏洞分析师。基于攻击过程生成正式的漏洞报告。

## 漏洞报告结构（遵循行业标准）

### 1. 执行摘要
- 漏洞概述（1-2 段）
- 风险等级（Critical/High/Medium/Low）
- 业务影响
- 修复优先级

### 2. 漏洞详情
- **漏洞类型**: OWASP Top 10 分类
- **CWE 编号**: 对应的 CWE ID
- **CVSS 评分**: 3.1 评分和向量
- **受影响组件**: 具体的 URL/端点/参数
- **漏洞原理**: 技术层面的成因分析

### 3. 复现步骤
- 前置条件
- 详细的复现步骤（可被第三方验证）
- 关键请求和响应
- PoC 代码

### 4. 影响分析
- 机密性影响（Confidentiality）
- 完整性影响（Integrity）
- 可用性影响（Availability）
- 潜在攻击场景

### 5. 修复建议
- 根本原因修复（代码层面）
- 缓解措施（配置层面）
- 防御深度建议
- 验证方法

### 6. 参考资料
- OWASP 指南
- CWE 链接
- 相关 CVE

## 输出格式

Markdown，正式技术报告风格，总字数 2000-4000 字。"#;

#[derive(Debug, Error)]
pub enum ReporterError {
    #[error("no flag captured, cannot generate writeup")]
    NoFlag,

    #[error("no findings available, cannot generate vulnerability report")]
    NoFindings,

    #[error("LLM call failed: {0}")]
    LlmError(#[from] anyhow::Error),

    #[error("IO error: {0}")]
    IoError(#[from] std::io::Error),

    #[error("both reports failed to generate")]
    AllFailed,

    #[error("output directory creation failed at {0}: {1}")]
    DirectoryCreation(PathBuf, String),
}

pub type Result<T> = std::result::Result<T, ReporterError>;

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Writeup {
    pub challenge_name: String,
    pub challenge_id: String,
    pub target_url: String,
    pub attack_type: String,
    pub difficulty: String,
    pub flag: String,
    pub content: String,
    pub generated_at: String,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct VulnerabilityReport {
    pub title: String,
    pub severity: String,
    pub cvss_score: f32,
    pub cwe_id: String,
    pub affected_component: String,
    pub vulnerability_type: String,
    pub content: String,
    pub generated_at: String,
}

#[derive(Debug, Default)]
pub struct ReportPaths {
    pub writeup: Option<PathBuf>,
    pub vulnerability_report: Option<PathBuf>,
}

pub struct Reporter;

impl Reporter {
    pub(crate) fn estimate_difficulty(iterations: usize, elapsed: f64) -> &'static str {
        match (iterations, elapsed) {
            (i, t) if i < 20 && t < 300.0 => "Easy",
            (i, t) if i < 50 && t < 900.0 => "Medium",
            (i, t) if i < 80 && t < 1800.0 => "Hard",
            _ => "Expert",
        }
    }

    pub(crate) fn estimate_cvss_score(attack_type: &str) -> f32 {
        match attack_type.to_lowercase().as_str() {
            "rce" => 9.8,
            "upload" => 8.8,
            "sqli" => 8.6,
            "auth_bypass" => 8.1,
            "ssrf" => 7.5,
            "crypto" => 7.4,
            "lfi" => 7.2,
            "idor" => 6.5,
            "xss" => 6.1,
            _ => 5.0,
        }
    }

    pub(crate) fn map_attack_type_to_cwe(attack_type: &str) -> &'static str {
        match attack_type.to_lowercase().as_str() {
            "sqli" => "CWE-89",
            "xss" => "CWE-79",
            "rce" => "CWE-78",
            "idor" => "CWE-639",
            "ssrf" => "CWE-918",
            "lfi" => "CWE-22",
            "auth_bypass" => "CWE-287",
            "upload" => "CWE-434",
            "crypto" => "CWE-327",
            _ => "CWE-Other",
        }
    }

    pub(crate) fn map_confidence_to_severity(confidence: &FindingConfidence) -> &'static str {
        match confidence {
            FindingConfidence::Confirmed => "High",
            FindingConfidence::Candidate => "Medium",
            FindingConfidence::Rejected => "Low",
        }
    }

    pub(crate) fn writeup_from_llm_text(
        state: &AttackState,
        flag: &str,
        attack_type: &str,
        iterations: usize,
        elapsed: f64,
        content: String,
    ) -> Writeup {
        Writeup {
            challenge_name: state.challenge_name().to_string(),
            challenge_id: state.challenge_id().to_string(),
            target_url: state.target_url().to_string(),
            attack_type: attack_type.to_string(),
            difficulty: Self::estimate_difficulty(iterations, elapsed).to_string(),
            flag: flag.to_string(),
            content,
            generated_at: chrono::Utc::now().to_rfc3339(),
        }
    }

    pub(crate) fn vuln_report_from_llm_text(
        state: &AttackState,
        content: String,
    ) -> Option<VulnerabilityReport> {
        let primary = state.findings().values().next()?;
        Some(VulnerabilityReport {
            title: format!("{} in {}", primary.finding_type, state.challenge_name()),
            severity: Self::map_confidence_to_severity(&primary.confidence).to_string(),
            cvss_score: Self::estimate_cvss_score(&primary.attack_type),
            cwe_id: Self::map_attack_type_to_cwe(&primary.attack_type).to_string(),
            affected_component: primary.details.clone(),
            vulnerability_type: primary.attack_type.clone(),
            content,
            generated_at: chrono::Utc::now().to_rfc3339(),
        })
    }

    pub async fn generate_and_save(
        &self,
        llm: &LlmClient,
        state: &AttackState,
        messages: &[Message],
        hypothesis_tracker: &HypothesisTracker,
        elapsed: f64,
        iterations: usize,
        output_root: &Path,
        event_sink: Option<&dyn AgentEventSink>,
    ) -> Result<ReportPaths> {
        let can_writeup = state.flag.is_some();
        let can_vuln = !state.findings().is_empty();

        if !can_writeup && !can_vuln {
            return Err(ReporterError::NoFlag);
        }

        let dir = Self::create_output_dir(output_root, state.challenge_id())?;
        let mut paths = ReportPaths::default();

        // --- Writeup ---
        if can_writeup {
            Self::emit(
                event_sink,
                AgentEvent::ReportGenerating {
                    report_type: "writeup".to_string(),
                },
            )
            .await;

            match self
                .generate_writeup(
                    llm,
                    state,
                    messages,
                    hypothesis_tracker,
                    elapsed,
                    iterations,
                )
                .await
            {
                Ok(wp) => {
                    let path = dir.join("writeup.md");
                    match std::fs::write(&path, &wp.content) {
                        Ok(_) => {
                            info!(path = %path.display(), "writeup saved");
                            Self::emit(
                                event_sink,
                                AgentEvent::ReportGenerated {
                                    report_type: "writeup".to_string(),
                                    file_path: path.to_string_lossy().to_string(),
                                },
                            )
                            .await;
                            paths.writeup = Some(path);
                        }
                        Err(e) => {
                            warn!(error = %e, "failed to write writeup");
                            Self::emit(
                                event_sink,
                                AgentEvent::ReportFailed {
                                    report_type: "writeup".to_string(),
                                    error: e.to_string(),
                                },
                            )
                            .await;
                        }
                    }
                }
                Err(e) => {
                    warn!(error = %e, "failed to generate writeup");
                    Self::emit(
                        event_sink,
                        AgentEvent::ReportFailed {
                            report_type: "writeup".to_string(),
                            error: e.to_string(),
                        },
                    )
                    .await;
                }
            }
        }

        // --- Vulnerability report ---
        if can_vuln {
            Self::emit(
                event_sink,
                AgentEvent::ReportGenerating {
                    report_type: "vulnerability_report".to_string(),
                },
            )
            .await;

            match self
                .generate_vulnerability_report(
                    llm,
                    state,
                    messages,
                    hypothesis_tracker,
                    elapsed,
                    iterations,
                )
                .await
            {
                Ok(vr) => {
                    let path = dir.join("vulnerability-report.md");
                    match std::fs::write(&path, &vr.content) {
                        Ok(_) => {
                            info!(path = %path.display(), "vulnerability report saved");
                            Self::emit(
                                event_sink,
                                AgentEvent::ReportGenerated {
                                    report_type: "vulnerability_report".to_string(),
                                    file_path: path.to_string_lossy().to_string(),
                                },
                            )
                            .await;
                            paths.vulnerability_report = Some(path);
                        }
                        Err(e) => {
                            warn!(error = %e, "failed to write vulnerability report");
                            Self::emit(
                                event_sink,
                                AgentEvent::ReportFailed {
                                    report_type: "vulnerability_report".to_string(),
                                    error: e.to_string(),
                                },
                            )
                            .await;
                        }
                    }
                }
                Err(e) => {
                    warn!(error = %e, "failed to generate vulnerability report");
                    Self::emit(
                        event_sink,
                        AgentEvent::ReportFailed {
                            report_type: "vulnerability_report".to_string(),
                            error: e.to_string(),
                        },
                    )
                    .await;
                }
            }
        }

        if paths.writeup.is_none() && paths.vulnerability_report.is_none() {
            return Err(ReporterError::AllFailed);
        }

        Ok(paths)
    }

    pub(crate) fn create_output_dir(base: &Path, challenge_id: &str) -> Result<PathBuf> {
        let timestamp = chrono::Utc::now().format("%Y%m%d-%H%M%S").to_string();
        let mut dir = base.join(format!("{}-{}", challenge_id, timestamp));

        let mut counter = 1;
        while dir.exists() {
            dir = base.join(format!("{}-{}-{}", challenge_id, timestamp, counter));
            counter += 1;
            if counter > 100 {
                return Err(ReporterError::DirectoryCreation(
                    dir,
                    "too many name collisions".to_string(),
                ));
            }
        }

        std::fs::create_dir_all(&dir)
            .map_err(|e| ReporterError::DirectoryCreation(dir.clone(), e.to_string()))?;

        Ok(dir)
    }

    pub(crate) fn build_attack_context(
        state: &AttackState,
        messages: &[Message],
        hypothesis_tracker: &HypothesisTracker,
        elapsed: f64,
        iterations: usize,
    ) -> String {
        const TOTAL_LIMIT: usize = 10_000;
        const TOOL_OUTPUT_LIMIT: usize = 500;

        let mut parts: Vec<String> = Vec::new();

        parts.push(format!(
            "**攻击统计**: {} 次迭代, 耗时 {:.1} 秒",
            iterations, elapsed
        ));

        let surface = state.attack_surface();
        if !surface.tech_stack.is_empty() {
            parts.push(format!("**技术栈**: {}", surface.tech_stack.join(", ")));
        }
        if !surface.ports.is_empty() {
            let ports: Vec<String> = surface
                .ports
                .iter()
                .map(|p| format!("{}/{}", p.port, p.service))
                .collect();
            parts.push(format!("**开放端口**: {}", ports.join(", ")));
        }

        let confirmed: Vec<String> = hypothesis_tracker
            .hypotheses
            .iter()
            .filter(|h| h.status == HypothesisStatus::Confirmed)
            .map(|h| format!("✓ [{}] {}", h.attack_type, h.description))
            .collect();
        let rejected: Vec<String> = hypothesis_tracker
            .hypotheses
            .iter()
            .filter(|h| h.status == HypothesisStatus::Rejected)
            .map(|h| {
                format!(
                    "✗ [{}] {} ({})",
                    h.attack_type,
                    h.description,
                    h.rejection_reason.as_deref().unwrap_or("超出尝试次数")
                )
            })
            .collect();
        if !confirmed.is_empty() {
            parts.push(format!("**成功假设**:\n{}", confirmed.join("\n")));
        }
        if !rejected.is_empty() {
            parts.push(format!("**失败假设**:\n{}", rejected.join("\n")));
        }

        let findings: Vec<String> = state
            .findings()
            .values()
            .map(|f: &Finding| {
                format!(
                    "- [{:?}] {} ({}): {}",
                    f.confidence, f.finding_type, f.attack_type, f.evidence
                )
            })
            .collect();
        if !findings.is_empty() {
            parts.push(format!("**漏洞发现**:\n{}", findings.join("\n")));
        }

        let evidence = state.evidence_bundle();
        if !evidence.credentials.is_empty() {
            let creds: Vec<String> = evidence
                .credentials
                .iter()
                .map(|c| format!("{}:{}", c.username, c.password))
                .collect();
            parts.push(format!("**获取凭据**: {}", creds.join(", ")));
        }

        let actions: Vec<String> = state
            .action_history
            .iter()
            .rev()
            .take(30)
            .rev()
            .cloned()
            .collect();
        if !actions.is_empty() {
            parts.push(format!("**关键操作**:\n{}", actions.join("\n")));
        }

        let tool_outputs: Vec<String> = messages
            .iter()
            .rev()
            .filter(|m| m.role == Role::Tool)
            .take(10)
            .collect::<Vec<_>>()
            .into_iter()
            .rev()
            .map(|m| {
                let name = m.name.as_deref().unwrap_or("tool");
                let content = m.content.as_deref().unwrap_or("");
                if content.len() > TOOL_OUTPUT_LIMIT {
                    let mut end = TOOL_OUTPUT_LIMIT;
                    while end > 0 && !content.is_char_boundary(end) {
                        end -= 1;
                    }
                    format!("[{}] {}...", name, &content[..end])
                } else {
                    format!("[{}] {}", name, content)
                }
            })
            .collect();
        if !tool_outputs.is_empty() {
            parts.push(format!(
                "**关键工具输出**:\n{}",
                tool_outputs.join("\n---\n")
            ));
        }

        let joined = parts.join("\n\n");
        if joined.len() > TOTAL_LIMIT {
            let mut end = TOTAL_LIMIT;
            while end > 0 && !joined.is_char_boundary(end) {
                end -= 1;
            }
            format!("{}\n[context truncated]", &joined[..end])
        } else {
            joined
        }
    }

    async fn generate_writeup(
        &self,
        llm: &LlmClient,
        state: &AttackState,
        messages: &[Message],
        hypothesis_tracker: &HypothesisTracker,
        elapsed: f64,
        iterations: usize,
    ) -> Result<Writeup> {
        let flag = state.flag.as_deref().ok_or(ReporterError::NoFlag)?;

        let context =
            Self::build_attack_context(state, messages, hypothesis_tracker, elapsed, iterations);

        let user_prompt = format!(
            r#"基于以下攻击过程，生成一份完整的 CTF Writeup。

## 挑战信息
- 名称: {}
- ID: {}
- URL: {}
- 提示: {}

## 攻击过程摘要
{}

## 要求
- 使用 Markdown 格式
- 包含完整的六个章节
- 突出关键思路转折点
- 总字数 1500-3000 字"#,
            state.challenge_name(),
            state.challenge_id(),
            state.target_url(),
            state.hints().join("; "),
            context
        );

        let response = llm
            .chat_completion_oneshot(WRITEUP_SYSTEM_PROMPT, &user_prompt, "skill_evolver")
            .await?;

        let content = response.content.unwrap_or_default();
        if content.trim().is_empty() {
            return Err(ReporterError::LlmError(anyhow::anyhow!(
                "empty LLM response"
            )));
        }

        Ok(Self::writeup_from_llm_text(
            state,
            flag,
            &state.current_attack_type,
            iterations,
            elapsed,
            content,
        ))
    }

    async fn generate_vulnerability_report(
        &self,
        llm: &LlmClient,
        state: &AttackState,
        messages: &[Message],
        hypothesis_tracker: &HypothesisTracker,
        elapsed: f64,
        iterations: usize,
    ) -> Result<VulnerabilityReport> {
        if state.findings().is_empty() {
            return Err(ReporterError::NoFindings);
        }

        let context =
            Self::build_attack_context(state, messages, hypothesis_tracker, elapsed, iterations);

        let findings_summary: Vec<String> = state
            .findings()
            .values()
            .map(|f| {
                format!(
                    "- [{:?}] {} ({})",
                    f.confidence, f.finding_type, f.attack_type
                )
            })
            .collect();

        let user_prompt = format!(
            r#"基于以下渗透测试结果，生成一份正式的安全漏洞报告。

## 目标系统
- 名称: {}
- URL: {}
- 技术栈: {}

## 发现的漏洞
{}

## 攻击过程详情
{}

## 要求
- 遵循行业标准漏洞报告格式
- 包含 CVSS 3.1 评分和向量
- 提供可复现的 PoC
- 使用 Markdown 格式
- 总字数 2000-4000 字"#,
            state.challenge_name(),
            state.target_url(),
            state.attack_surface().tech_stack.join(", "),
            findings_summary.join("\n"),
            context
        );

        let response = llm
            .chat_completion_oneshot(VULN_REPORT_SYSTEM_PROMPT, &user_prompt, "skill_evolver")
            .await?;

        let content = response.content.unwrap_or_default();
        if content.trim().is_empty() {
            return Err(ReporterError::LlmError(anyhow::anyhow!(
                "empty LLM response"
            )));
        }

        Self::vuln_report_from_llm_text(state, content).ok_or(ReporterError::NoFindings)
    }

    /// Regenerate reports from a saved AttackResult JSON. This path has less fidelity
    /// than the live in-process flow — only the top-level fields survive — so the
    /// prompts fall back to them.
    pub async fn generate_from_result(
        &self,
        llm: &LlmClient,
        result: &crate::result::AttackResult,
        output_root: &Path,
        want_writeup: bool,
        want_vuln: bool,
    ) -> Result<ReportPaths> {
        let challenge_id = result
            .action_summary
            .first()
            .cloned()
            .unwrap_or_else(|| "regenerated".to_string());
        let dir = Self::create_output_dir(output_root, &challenge_id)?;
        let mut paths = ReportPaths::default();

        if want_writeup {
            let flag = result.flag.clone().ok_or(ReporterError::NoFlag)?;
            let user_prompt = format!(
                "重新基于以下 JSON 攻击结果生成 CTF Writeup:\n\n{}",
                serde_json::to_string_pretty(result).unwrap_or_default()
            );
            let response = llm
                .chat_completion_oneshot(WRITEUP_SYSTEM_PROMPT, &user_prompt, "skill_evolver")
                .await?;
            let content = response.content.unwrap_or_default();
            if !content.trim().is_empty() {
                let path = dir.join("writeup.md");
                std::fs::write(&path, &content)?;
                paths.writeup = Some(path);
                let _ = flag; // flag is required by contract (writeup prerequisite)
            }
        }

        if want_vuln {
            if result.findings.is_empty() {
                return if paths.writeup.is_some() {
                    Ok(paths)
                } else {
                    Err(ReporterError::NoFindings)
                };
            }
            let user_prompt = format!(
                "重新基于以下 JSON 攻击结果生成正式漏洞报告:\n\n{}",
                serde_json::to_string_pretty(result).unwrap_or_default()
            );
            let response = llm
                .chat_completion_oneshot(VULN_REPORT_SYSTEM_PROMPT, &user_prompt, "skill_evolver")
                .await?;
            let content = response.content.unwrap_or_default();
            if !content.trim().is_empty() {
                let path = dir.join("vulnerability-report.md");
                std::fs::write(&path, &content)?;
                paths.vulnerability_report = Some(path);
            }
        }

        if paths.writeup.is_none() && paths.vulnerability_report.is_none() {
            return Err(ReporterError::AllFailed);
        }
        Ok(paths)
    }

    /// Silently ignore if sink is None. Used by LLM-call paths that may be invoked
    /// without a web context.
    async fn emit(sink: Option<&dyn AgentEventSink>, event: AgentEvent) {
        if let Some(s) = sink {
            s.send(event).await;
        }
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn difficulty_easy_bucket() {
        assert_eq!(Reporter::estimate_difficulty(15, 200.0), "Easy");
    }

    #[test]
    fn difficulty_medium_bucket() {
        assert_eq!(Reporter::estimate_difficulty(35, 600.0), "Medium");
    }

    #[test]
    fn difficulty_hard_bucket() {
        assert_eq!(Reporter::estimate_difficulty(75, 1500.0), "Hard");
    }

    #[test]
    fn difficulty_expert_fallback() {
        assert_eq!(Reporter::estimate_difficulty(100, 2000.0), "Expert");
    }

    #[test]
    fn cvss_known_types() {
        assert_eq!(Reporter::estimate_cvss_score("rce"), 9.8);
        assert_eq!(Reporter::estimate_cvss_score("SQLi"), 8.6);
        assert_eq!(Reporter::estimate_cvss_score("xss"), 6.1);
    }

    #[test]
    fn cvss_unknown_defaults_to_5() {
        assert_eq!(Reporter::estimate_cvss_score("mystery"), 5.0);
    }

    #[test]
    fn cwe_mapping() {
        assert_eq!(Reporter::map_attack_type_to_cwe("sqli"), "CWE-89");
        assert_eq!(Reporter::map_attack_type_to_cwe("XSS"), "CWE-79");
        assert_eq!(Reporter::map_attack_type_to_cwe("unknown"), "CWE-Other");
    }

    #[test]
    fn confidence_severity_mapping() {
        assert_eq!(
            Reporter::map_confidence_to_severity(&FindingConfidence::Confirmed),
            "High"
        );
        assert_eq!(
            Reporter::map_confidence_to_severity(&FindingConfidence::Candidate),
            "Medium"
        );
        assert_eq!(
            Reporter::map_confidence_to_severity(&FindingConfidence::Rejected),
            "Low"
        );
    }

    #[test]
    fn create_output_dir_produces_timestamped_path() {
        let tmp = std::env::temp_dir().join(format!("apeiron-report-test-{}", std::process::id()));
        let _ = std::fs::remove_dir_all(&tmp);

        let dir = Reporter::create_output_dir(&tmp, "ch-abc").unwrap();

        assert!(dir.exists());
        let name = dir.file_name().unwrap().to_string_lossy().to_string();
        assert!(name.starts_with("ch-abc-"));
        assert!(dir.starts_with(&tmp));

        let _ = std::fs::remove_dir_all(&tmp);
    }

    #[test]
    fn create_output_dir_disambiguates_on_collision() {
        let tmp =
            std::env::temp_dir().join(format!("apeiron-report-collide-{}", std::process::id()));
        let _ = std::fs::remove_dir_all(&tmp);

        // Pre-create the exact directory create_output_dir would produce.
        let timestamp = chrono::Utc::now().format("%Y%m%d-%H%M%S").to_string();
        let base = tmp.join(format!("ch-dup-{}", timestamp));
        std::fs::create_dir_all(&base).unwrap();

        let dir = Reporter::create_output_dir(&tmp, "ch-dup").unwrap();

        assert_ne!(dir, base);
        assert!(
            dir.file_name().unwrap().to_string_lossy().ends_with("-1")
                || dir.file_name().unwrap().to_string_lossy().ends_with("-2")
        );

        let _ = std::fs::remove_dir_all(&tmp);
    }

    use holmes_core::state::AttackState;

    fn make_state() -> AttackState {
        AttackState::new(
            "http://target.local".to_string(),
            "127.0.0.1".to_string(),
            "ch-001".to_string(),
            "Sample".to_string(),
            vec!["try login".to_string()],
        )
    }

    #[test]
    fn context_includes_statistics_header() {
        let state = make_state();
        let tracker = HypothesisTracker::new(5);
        let ctx = Reporter::build_attack_context(&state, &[], &tracker, 123.4, 17);
        assert!(ctx.contains("17"));
        assert!(ctx.contains("123.4"));
    }

    #[test]
    fn context_truncates_long_tool_output() {
        let state = make_state();
        let tracker = HypothesisTracker::new(5);

        let long = "x".repeat(2000);
        let tool_msg = Message {
            role: Role::Tool,
            content: Some(long.clone()),
            name: Some("curl".to_string()),
            tool_call_id: Some("call-1".to_string()),
            tool_calls: None,
            image_blocks: None,
        };

        let ctx = Reporter::build_attack_context(&state, &[tool_msg], &tracker, 1.0, 1);
        assert!(ctx.contains("..."));
        assert!(!ctx.contains(&long));
    }

    #[test]
    fn context_total_length_bounded() {
        let state = make_state();
        let tracker = HypothesisTracker::new(5);
        let big = "y".repeat(400);
        let messages: Vec<Message> = (0..50)
            .map(|i| Message {
                role: Role::Tool,
                content: Some(big.clone()),
                name: Some(format!("tool-{i}")),
                tool_call_id: Some(format!("call-{i}")),
                tool_calls: None,
                image_blocks: None,
            })
            .collect();

        let ctx = Reporter::build_attack_context(&state, &messages, &tracker, 1.0, 1);
        assert!(ctx.len() <= 10_000 + "[context truncated]".len() + 4);
    }

    #[test]
    fn writeup_from_parts_assembles_markdown() {
        let state = make_state();
        let wp = Reporter::writeup_from_llm_text(
            &state,
            "flag{abc}",
            "sqli",
            18,
            120.0,
            "# Content body".to_string(),
        );
        assert_eq!(wp.challenge_id, "ch-001");
        assert_eq!(wp.challenge_name, "Sample");
        assert_eq!(wp.target_url, "http://target.local");
        assert_eq!(wp.flag, "flag{abc}");
        assert_eq!(wp.attack_type, "sqli");
        assert_eq!(wp.difficulty, "Easy");
        assert!(wp.content.contains("# Content body"));
        assert!(!wp.generated_at.is_empty());
    }

    #[test]
    fn vuln_report_from_parts_uses_primary_finding() {
        let mut state = make_state();
        let f = Finding {
            id: "f1".to_string(),
            finding_type: "SQL Injection in login".to_string(),
            confidence: FindingConfidence::Confirmed,
            evidence: "error-based payload succeeded".to_string(),
            details: "/login username parameter".to_string(),
            attack_type: "sqli".to_string(),
        };
        state.findings_mut().insert("f1".to_string(), f);

        let vr =
            Reporter::vuln_report_from_llm_text(&state, "body".to_string()).expect("has findings");
        assert_eq!(vr.cwe_id, "CWE-89");
        assert_eq!(vr.cvss_score, 8.6);
        assert_eq!(vr.severity, "High");
        assert_eq!(vr.affected_component, "/login username parameter");
        assert_eq!(vr.vulnerability_type, "sqli");
        assert!(vr.title.contains("SQL Injection"));
        assert!(vr.content.contains("body"));
    }

    #[test]
    fn vuln_report_returns_none_without_findings() {
        let state = make_state();
        assert!(Reporter::vuln_report_from_llm_text(&state, "body".into()).is_none());
    }

    fn dummy_llm() -> LlmClient {
        LlmClient::new(&holmes_core::config::Config::default())
    }

    #[tokio::test]
    async fn generate_and_save_errors_when_no_flag_and_no_findings() {
        let state = make_state(); // no flag, no findings
        let tracker = HypothesisTracker::new(5);
        let reporter = Reporter;
        let llm = dummy_llm();

        let tmp = std::env::temp_dir().join(format!("apeiron-report-empty-{}", std::process::id()));
        let _ = std::fs::remove_dir_all(&tmp);

        let err = reporter
            .generate_and_save(&llm, &state, &[], &tracker, 10.0, 3, &tmp, None)
            .await
            .unwrap_err();

        match err {
            ReporterError::NoFlag => {}
            other => panic!("expected NoFlag, got {:?}", other),
        }

        let _ = std::fs::remove_dir_all(&tmp);
    }
}
